{
  "name": "form-mate",
  "version": "4.2.0",
  "description": "A tiny and elegant library to handle forms with React",
  "homepage": "https://form-mate.dev/",
  "repository": "github:franciscop/form-mate",
  "funding": "https://www.paypal.me/franciscopresencia/19",
  "author": "Francisco Presencia <public@francisco.io> (https://francisco.io/)",
  "license": "MIT",
  "keywords": [
    "react",
    "form",
    "manager",
    "state",
    "error"
  ],
  "scripts": {
    "build": "npm run build:library && npm run build:types && npm run build:prettier",
    "build:library": "vite build && mv dist/index.min.js . && rm -rf dist",
    "build:types": "dts-bundle-generator --out-file index.d.ts src/index.tsx",
    "build:prettier": "prettier src *.ts *.json --write",
    "lint": "tsc",
    "size": "echo $(gzip -c index.min.js | wc -c) bytes",
    "start": "vitest",
    "test": "vitest run --coverage"
  },
  "main": "index.min.js",
  "type": "module",
  "types": "index.d.ts",
  "files": [
    "index.d.ts"
  ],
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.4",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "^0.27.7",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-test": "^0.24.8",
    "terser": "^5.46.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "documentation": {
    "menu": {
      "Author": "https://francisco.io/",
      "Donate": "https://www.paypal.me/franciscopresencia/19",
      "npm": "https://www.npmjs.com/package/form-mate",
      "Github": "https://github.com/franciscop/form-mate"
    }
  }
}
